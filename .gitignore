# Build output
bin/
obj/

# Sync tooling — local cherry-pick script from the private development fork; not published.
sync-from-*.ps1

# Test infrastructure — must never cross the public boundary.
# Test projects live in the private development fork and are mirrored into
# tests-local/ only for local validation against this public clone.
tests-local/
*.WithTests.sln

# Signing keys — strong-name private keys must stay private.
# The public Puppeteer.csproj drops SignAssembly entirely, so the
# .snk has no business living here. These guards block accidental
# crossings.
PuppeteerKey.snk
*.snk

# IDE / user-local
.vs/
*.user
*.suo
.idea/
*.DotSettings.user

# Local build/test logs from `dotnet build` / `dotnet test` runs.
build.log
test.log

# Lab tests write their CSV outputs to a sibling-repo relative path
# (puppeteer-papers/data/...). When run from this clone, that path
# resolves inside the working tree. The lab data belongs in the
# puppeteer-papers repo, not here.
puppeteer-papers/

# OS junk
Thumbs.db
.DS_Store
